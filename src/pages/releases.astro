---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';

const REPO = 'Walter-Sparrow/lunar-tear';
---

<StarlightPage
	frontmatter={{
		title: 'Releases',
		description: `Release history for ${REPO} on GitHub.`,
	}}
>
	<div id="releases" data-repo={REPO}>
		<p class="loading">Loading releases…</p>
	</div>
</StarlightPage>

<script>
	import { renderMarkdown } from '../lib/markdown';

	type Release = {
		id: number;
		name: string | null;
		tag_name: string;
		html_url: string;
		published_at: string | null;
		body: string | null;
		prerelease: boolean;
		draft: boolean;
		author: { login: string; html_url: string } | null;
	};

	function formatDate(iso: string | null): string {
		if (!iso) return '';
		return new Date(iso).toLocaleDateString('en-US', {
			year: 'numeric',
			month: 'long',
			day: 'numeric',
		});
	}

	function link(href: string, text: string): HTMLAnchorElement {
		const a = document.createElement('a');
		a.href = href;
		a.target = '_blank';
		a.rel = 'noopener noreferrer';
		a.textContent = text;
		return a;
	}

	function renderEmpty(container: HTMLElement, repo: string) {
		const div = document.createElement('div');
		div.className = 'empty';
		const p = document.createElement('p');
		p.append(
			"No releases found yet, or GitHub's API is rate-limiting you. Check the ",
			link(`https://github.com/${repo}/releases`, 'releases page on GitHub'),
			' directly.',
		);
		div.append(p);
		container.replaceChildren(div);
	}

	function renderReleases(container: HTMLElement, releases: Release[]) {
		const frag = document.createDocumentFragment();
		for (const release of releases) {
			const article = document.createElement('article');
			article.className = 'release';

			const header = document.createElement('header');
			const h2 = document.createElement('h2');
			h2.append(link(release.html_url, release.name?.trim() || release.tag_name));
			if (release.prerelease) {
				const badge = document.createElement('span');
				badge.className = 'badge pre';
				badge.textContent = 'Pre-release';
				h2.append(badge);
			}

			const meta = document.createElement('p');
			meta.className = 'meta';
			const tag = document.createElement('code');
			tag.textContent = release.tag_name;
			meta.append(tag);
			if (release.published_at) {
				const dot = document.createElement('span');
				dot.className = 'dot';
				dot.textContent = '·';
				const time = document.createElement('time');
				time.dateTime = release.published_at;
				time.textContent = formatDate(release.published_at);
				meta.append(dot, time);
			}
			if (release.author) {
				const dot = document.createElement('span');
				dot.className = 'dot';
				dot.textContent = '·';
				meta.append(dot, link(release.author.html_url, `@${release.author.login}`));
			}

			header.append(h2, meta);

			const body = document.createElement('div');
			body.className = 'body';
			body.innerHTML = renderMarkdown(release.body ?? '', { headingShift: 2 });

			article.append(header, body);
			frag.append(article);
		}
		container.replaceChildren(frag);
	}

	async function load() {
		const container = document.getElementById('releases');
		if (!container) return;
		const repo = container.dataset.repo ?? '';
		try {
			const res = await fetch(`https://api.github.com/repos/${repo}/releases?per_page=50`, {
				headers: {
					Accept: 'application/vnd.github+json',
					'X-GitHub-Api-Version': '2022-11-28',
				},
			});
			if (!res.ok) {
				renderEmpty(container, repo);
				return;
			}
			const data = (await res.json()) as Release[];
			const releases = data.filter((r) => !r.draft);
			if (releases.length === 0) {
				renderEmpty(container, repo);
				return;
			}
			renderReleases(container, releases);
		} catch {
			renderEmpty(container, repo);
		}
	}

	load();
</script>

<style>
	#releases :global(.loading) {
		color: var(--sl-color-gray-3);
	}
	#releases :global(.release) {
		padding: 1.5rem 0;
		border-bottom: 1px solid var(--sl-color-hairline-light);
	}
	#releases :global(.release:last-child) {
		border-bottom: none;
	}
	#releases :global(.release header h2) {
		margin: 0;
		display: flex;
		align-items: center;
		gap: 0.75rem;
		flex-wrap: wrap;
	}
	#releases :global(.release header h2 a) {
		color: var(--sl-color-white);
		text-decoration: none;
	}
	#releases :global(.release header h2 a:hover) {
		text-decoration: underline;
	}
	#releases :global(.meta) {
		margin: 0.5rem 0 1rem;
		font-size: var(--sl-text-sm);
		color: var(--sl-color-gray-3);
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.5rem;
	}
	#releases :global(.meta code) {
		font-size: 0.85em;
	}
	#releases :global(.dot) {
		opacity: 0.5;
	}
	#releases :global(.badge) {
		font-size: 0.7em;
		padding: 0.15rem 0.5rem;
		border-radius: 999px;
		background: var(--sl-color-orange-low);
		color: var(--sl-color-orange-high);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
	#releases :global(.body h3),
	#releases :global(.body h4),
	#releases :global(.body h5),
	#releases :global(.body h6) {
		margin-top: 1.25rem;
	}
	#releases :global(.body ul) {
		padding-left: 1.5rem;
	}
	#releases :global(.empty) {
		padding: 1rem;
		border: 1px dashed var(--sl-color-hairline);
		border-radius: 0.5rem;
		color: var(--sl-color-gray-3);
	}
</style>
