---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';

const REPO = 'Walter-Sparrow/lunar-tear';
const BRANCH = 'main';
const PATH = 'docs/CHANGELOG.md';
const RAW_URL = `https://raw.githubusercontent.com/${REPO}/${BRANCH}/${PATH}`;
const SOURCE_URL = `https://github.com/${REPO}/blob/${BRANCH}/${PATH}`;
---

<StarlightPage
	frontmatter={{
		title: 'Changelog',
		description:
			'Ongoing development progress for Lunar Tear — what works, what was fixed, and what is still being figured out.',
	}}
>
	<div id="changelog" data-raw={RAW_URL} data-source={SOURCE_URL}>
		<p class="loading">Loading changelog…</p>
	</div>
</StarlightPage>

<script>
	import { renderMarkdown } from '../lib/markdown';

	function stripLeadingH1(md: string): string {
		const lines = md.replace(/\r\n/g, '\n').split('\n');
		const i = lines.findIndex((l) => l.trim() !== '');
		if (i >= 0 && /^#\s+/.test(lines[i])) {
			return lines.slice(i + 1).join('\n').replace(/^\n+/, '');
		}
		return md;
	}

	function renderEmpty(container: HTMLElement, source: string) {
		const div = document.createElement('div');
		div.className = 'empty';
		const p = document.createElement('p');
		const a = document.createElement('a');
		a.href = source;
		a.target = '_blank';
		a.rel = 'noopener noreferrer';
		a.textContent = 'GitHub';
		p.append("Couldn't load the changelog right now. Read it directly on ", a, '.');
		div.append(p);
		container.replaceChildren(div);
	}

	async function load() {
		const container = document.getElementById('changelog');
		if (!container) return;
		const raw = container.dataset.raw ?? '';
		const source = container.dataset.source ?? '';
		try {
			const res = await fetch(raw);
			if (!res.ok) {
				renderEmpty(container, source);
				return;
			}
			const text = await res.text();
			const div = document.createElement('div');
			div.className = 'changelog';
			div.innerHTML = renderMarkdown(stripLeadingH1(text));
			container.replaceChildren(div);
		} catch {
			renderEmpty(container, source);
		}
	}

	load();
</script>

<style>
	#changelog :global(.loading) {
		color: var(--sl-color-gray-3);
	}
	#changelog :global(.changelog h2) {
		margin-top: 2.5rem;
		padding-top: 1.5rem;
		border-top: 1px solid var(--sl-color-hairline-light);
	}
	#changelog :global(.changelog h2:first-of-type) {
		margin-top: 1.5rem;
		padding-top: 0;
		border-top: none;
	}
	#changelog :global(.changelog h3) {
		margin-top: 1.5rem;
		font-size: var(--sl-text-lg);
		color: var(--sl-color-gray-2);
	}
	#changelog :global(.changelog ul) {
		padding-left: 1.5rem;
	}
	#changelog :global(.empty) {
		padding: 1rem;
		border: 1px dashed var(--sl-color-hairline);
		border-radius: 0.5rem;
		color: var(--sl-color-gray-3);
	}
</style>
